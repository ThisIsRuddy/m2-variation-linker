{
    "name": "m2-variation-linker-v2",
    "version": "0.0.0",
    "description": "A script for linking simple & configurable products in Magento.",
    "scripts": {
        "link:prod": "node -r dotenv/config src/link.js dotenv_config_path=.env.production",
        "link:stag": "node -r dotenv/config src/link.js dotenv_config_path=.env.staging",
        "link:local": "node -r dotenv/config src/link.js dotenv_config_path=.env.local",
        "unlink:prod": "node -r dotenv/config src/unlink.js dotenv_config_path=.env.production",
        "unlink:stag": "node -r dotenv/config src/unlink.js dotenv_config_path=.env.staging",
        "unlink:local": "node -r dotenv/config src/unlink.js dotenv_config_path=.env.local",
        "attributes:create:prod": "node -r dotenv/config src/createAttributeOptions.js dotenv_config_path=.env.production",
        "attributes:update:prod": "node -r dotenv/config src/updateAttributeOptions.js dotenv_config_path=.env.production",
        "attributes:create:stag": "node -r dotenv/config src/createAttributeOptions.js dotenv_config_path=.env.staging",
        "attributes:update:stag": "node -r dotenv/config src/updateAttributeOptions.js dotenv_config_path=.env.staging",
        "attributes:create:local": "node -r dotenv/config src/createAttributeOptions.js dotenv_config_path=.env.local",
        "attributes:update:local": "node -r dotenv/config src/updateAttributeOptions.js dotenv_config_path=.env.local",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@eslint/js": "^9.2.0",
        "eslint": "^9.2.0",
        "eslint-config-prettier": "^10.1.0",
        "globals": "^16.0.0",
        "prettier": "^3.4.2"
    },
    "dependencies": {
        "dotenv": "^16.4.5"
    }
}
